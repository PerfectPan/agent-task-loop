{
  "name": "@rivus/agent-finder-core",
  "version": "0.1.2",
  "private": false,
  "description": "Read-only local code agent discovery core for JavaScript consumers.",
  "license": "GPL-3.0-only",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/PerfectPan/agent-task-loop",
    "directory": "packages/agent-finder"
  },
  "bugs": {
    "url": "https://github.com/PerfectPan/agent-task-loop/issues"
  },
  "homepage": "https://github.com/PerfectPan/agent-task-loop#readme",
  "keywords": [
    "ai-agent",
    "coding-agent",
    "discovery",
    "inventory"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "src/**/*.ts",
    "src/moonbit/agent_discovery_core.js",
    "src/moonbit/agent_discovery_core.d.ts",
    "src/moonbit/moonbit.d.ts",
    "README.md",
    "moon.mod.json",
    "agent_discovery_core/"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "build": "rslib build",
    "dev": "tsx src/index.ts",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm test",
    "test": "rslib build && vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@rsbuild/core": "^2.0.3",
    "@rslib/core": "^0.21.3",
    "@rivus/rslib-config": "workspace:*",
    "@types/node": "^22.15.3",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
