{
  "name": "@rivus/agent-finder-cli",
  "version": "0.1.0",
  "private": false,
  "description": "Command-line interface for local code agent discovery.",
  "license": "GPL-3.0-only",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/PerfectPan/agent-task-loop",
    "directory": "packages/agent-finder-cli"
  },
  "bugs": {
    "url": "https://github.com/PerfectPan/agent-task-loop/issues"
  },
  "homepage": "https://github.com/PerfectPan/agent-task-loop#readme",
  "keywords": [
    "ai-agent",
    "coding-agent",
    "discovery",
    "inventory",
    "cli"
  ],
  "bin": {
    "agent-finder": "./bin/agent-finder.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "files": [
    "bin/",
    "dist/",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "build": "rslib build",
    "dev": "tsx --conditions=development src/cli.ts",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm test",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@rivus/agent-finder-core": "workspace:*",
    "citty": "^0.1.6"
  },
  "devDependencies": {
    "@rsbuild/core": "^2.0.3",
    "@rslib/core": "^0.21.3",
    "@rivus/rslib-config": "workspace:*",
    "@types/node": "^22.15.3",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
