{
  "name": "agent-task-loop-monorepo",
  "private": true,
  "license": "GPL-3.0-only",
  "packageManager": "pnpm@9.15.9",
  "dependencies": {
    "@rivus/agent-finder-cli": "workspace:*",
    "@rivus/agent-task-loop": "workspace:*"
  },
  "scripts": {
    "agent-finder": "pnpm --filter @rivus/agent-finder-cli dev",
    "build": "pnpm -r build",
    "changeset": "changeset",
    "check:moonbit-version": "node scripts/sync-moonbit-version.mjs --check",
    "release": "pnpm build && changeset publish",
    "sync:moonbit-version": "node scripts/sync-moonbit-version.mjs",
    "test": "node --test tests/**/*.test.mjs && pnpm -r test && moon -C packages/agent-finder test",
    "version-packages": "changeset version && pnpm sync:moonbit-version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@microsoft/api-extractor": "^7.58.8",
    "@rslib/core": "^0.21.3"
  }
}
